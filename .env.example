# Supabase client keys (safe for frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-side only - NEVER expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: Supabase Edge Function URL for production teacher registration
# Set this to your Supabase Edge Function URL when deployed
# e.g. https://dbhaitdxwimhmwpwjogb.functions.supabase.co
# VITE_EDGE_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1
