# ─── Client-side (VITE_ prefix — safe for frontend) ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Server-side only (used by Vercel API routes) ───
# Set these in Vercel Dashboard → Settings → Environment Variables
# DO NOT prefix with VITE_ or NEXT_PUBLIC_
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend API key for password reset emails (used by Edge Functions)
# Get one at https://resend.com
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@kizaga-rms.com
